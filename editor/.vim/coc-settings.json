{
    "rust-analyzer.checkOnSave": false,

    "python.venvPath": "/Users/mfpr/venvs",
    "pyright.typeCheckingMode": "off",
    "python.formatting.provider": "ruff",

    "workspace.progressTarget": "statusline",
    "ui.dialogTarget": "menu",
    "typescript.highlight.locations": false,

    "coc.suggest.floatEnable": false,
    "coc.preferences.floatActions": false,
    "coc.preferences.enableHighlight": false,
    "coc.preferences.useQuickfixForLocations": true,

    "rust-analyzer.inlayHints.enable": false,
    "rust-analyzer.inlayHints.typeHints.enable": false,
    "rust-analyzer.inlayHints.expressionAdjustmentHints.enable": "never",
    "rust-analyzer.inlayHints.parameterHints.enable": false,
    "rust-analyzer.inlayHints.chainingHints.enable": false,
    "rust-analyzer.inlayHints.closingBraceHints.enable": false,
    "rust-analyzer.displayContextHints.enable": false

}

